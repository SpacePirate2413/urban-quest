generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatarUrl String?
  bio       String?
  genres    String?  // comma-separated genre list
  birthdate DateTime?
  role      String   @default("player") // player | writer | admin

  provider   String // GOOGLE | APPLE | DEV
  providerId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
  suspendedAt DateTime?
  bannedAt    DateTime?

  // Stripe Connect Express — for creator payouts on paid quest revenue.
  // `accountId` is the Stripe acct_xxx; `status` mirrors the most recent
  // onboarding state we observed (pending | active | restricted).
  stripeConnectAccountId String?
  stripeConnectStatus    String? @default("pending")

  // Relations
  quests         Quest[]
  purchases      Purchase[]
  reviews        Review[]
  scoutedWaypoints ScoutedWaypoint[]
  reportsFiled    Report[]    @relation("ReportsByReporter")
  reportsResolved Report[]    @relation("ReportsByResolver")
  blocking        UserBlock[] @relation("Blocker")
  blockedBy       UserBlock[] @relation("Blocked")

  @@unique([provider, providerId])
  @@index([email])
}

model Quest {
  id          String   @id @default(cuid())
  title       String
  description String?
  tagline     String?
  genre       String   @default("Adventure")
  ageRating   String   @default("E") // E | E10+ | T | M
  price       Float    @default(0)
  status      String   @default("draft") // draft | review | published | archived
  coverImage  String?
  usesAI      Boolean  @default(false)
  narratorVoiceId String?
  mediaType   String?  // audio | video | both — creator's declared format. 'both' allows mixed scenes.
  submissionStatus String? // draft | pending | approved | rejected
  
  // Stats
  estimatedDuration Int? // minutes
  totalDistance     Float? // km
  playCount         Int    @default(0)
  
  // Location
  startLat    Float?
  startLng    Float?
  city        String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  publishedAt DateTime?
  
  // Relations
  authorId   String
  author     User       @relation(fields: [authorId], references: [id])
  waypoints  Waypoint[]
  scenes     Scene[]
  purchases  Purchase[]
  reviews    Review[]
  
  @@index([status])
  @@index([authorId])
  @@index([city])
}

model Waypoint {
  id          String  @id @default(cuid())
  name        String
  notes       String?
  photoUrl    String?
  lat         Float
  lng         Float
  orderIndex  Int     @default(0)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  questId String
  quest   Quest   @relation(fields: [questId], references: [id], onDelete: Cascade)
  scenes  Scene[]
  
  @@index([questId])
}

model Scene {
  id         String  @id @default(cuid())
  script     String
  question   String?
  choices    String? // JSON array of choices
  orderIndex Int     @default(0)

  // Per-scene narrator override. When null, the player falls back to the
  // owning quest's narratorVoiceId. The creator picks this in the AI Narrate
  // modal; it is also stamped onto the quest as the new "last-used default"
  // so subsequent scenes pre-select the same voice (Q1c hybrid scope).
  narratorVoiceId String?

  // Media
  mediaUrl    String?
  mediaType   String? // audio | video
  mediaStatus String? // pending | approved | rejected
  // Free-text feedback the admin reviewer typed when approving/rejecting
  // this scene. Surfaces in the creator's Create tab so they know what to
  // change before resubmitting.
  reviewNotes String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  questId    String
  quest      Quest    @relation(fields: [questId], references: [id], onDelete: Cascade)
  waypointId String?
  waypoint   Waypoint? @relation(fields: [waypointId], references: [id])
  
  @@index([questId])
  @@index([waypointId])
}

model Purchase {
  id            String   @id @default(cuid())
  amount        Float
  currency      String   @default("USD")
  paymentMethod String?  // apple_pay | google_pay | card
  status        String   @default("completed") // pending | completed | refunded
  
  createdAt DateTime @default(now())
  
  // Progress tracking
  currentSceneId String?
  completedAt    DateTime?
  
  // Relations
  userId  String
  user    User   @relation(fields: [userId], references: [id])
  questId String
  quest   Quest  @relation(fields: [questId], references: [id], onDelete: Cascade)
  
  @@unique([userId, questId])
  @@index([userId])
  @@index([questId])
}

model Review {
  id      String @id @default(cuid())
  rating  Int    // 1-5
  comment String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  userId  String
  user    User   @relation(fields: [userId], references: [id])
  questId String
  quest   Quest  @relation(fields: [questId], references: [id], onDelete: Cascade)
  
  @@unique([userId, questId])
  @@index([questId])
}

// Polymorphic moderation report. entityType is one of: 'quest' | 'scene' | 'review' | 'user'.
// entityId points at the corresponding row. We don't FK because Prisma doesn't support
// polymorphic relations cleanly; service code must validate the target exists.
model Report {
  id        String @id @default(cuid())

  reporterId String
  reporter   User   @relation("ReportsByReporter", fields: [reporterId], references: [id])

  entityType String // quest | scene | review | user
  entityId   String

  reason  String  // spam | harassment | sexual_minors | hate | violence | illegal | ip | scam | impersonation | other
  details String? // free-text additional context from the reporter

  status String @default("pending") // pending | resolved | dismissed

  resolvedAt   DateTime?
  resolvedById String?
  resolvedBy   User?     @relation("ReportsByResolver", fields: [resolvedById], references: [id])
  action       String?   // dismiss | remove_content | suspend_user | ban_user
  notes        String?   // admin notes on resolution

  createdAt DateTime @default(now())

  @@index([status])
  @@index([entityType, entityId])
  @@index([reporterId])
  @@index([createdAt])
}

model UserBlock {
  id String @id @default(cuid())

  blockerId String
  blocker   User   @relation("Blocker", fields: [blockerId], references: [id])

  blockedId String
  blocked   User   @relation("Blocked", fields: [blockedId], references: [id])

  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

model ScoutedWaypoint {
  id          String   @id @default(cuid())
  name        String
  notes       String?
  lat         Float
  lng         Float
  photos      String?  // JSON array of URLs
  videos      String?  // JSON array of URLs
  audioRecordings String? // JSON array of URLs
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id])
  
  @@index([userId])
}
